# Database
POSTGRES_DB=nakama
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localdb

# Nakama DB connection
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nakama
DB_USER=postgres
DB_PASSWORD=localdb

# Nakama runtime settings
NAKAMA_LOG_LEVEL=INFO
NAKAMA_CONSOLE_USERNAME=admin
NAKAMA_CONSOLE_PASSWORD=change_me_console_password
NAKAMA_SERVER_KEY=change_me_server_key

# Production image source and rollout settings
GHCR_NAMESPACE=your-github-username
IMAGE_TAG=latest
WATCHTOWER_POLL_INTERVAL=60

# Frontend build-time Nakama settings (Vite)
VITE_NAKAMA_HOST=127.0.0.1
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_KEY=change_me_server_key
VITE_NAKAMA_SSL=false

# Host port for frontend container
FRONTEND_PORT=5173
